              '<span style="font-weight:600">' + (tp.author_name || '未知') + '</span>' +
              '<span style="color:var(--text-muted)">' + (tp.author_role || '') + '</span>' +
              '<span style="color:var(--text-muted);margin-left:4px">' + (tp.created_at ? '创建于 ' + new Date(tp.created_at).toLocaleString('zh-CN') : '') + '</span>' +
            '</div>' +
            (isGenerating ? '' : retrievalHtml) +
            (isGenerating ? deepModeForm :
             '<div style="margin-bottom:24px;padding:20px;background:var(--bg-secondary);border-radius:8px;border-left:3px solid var(--accent-blue);max-height:50vh;overflow-y:auto">' + rendered + '</div>') +
            '<div style="text-align:right;display:flex;gap:8px;justify-content:flex-end">' +
              '<button class="btn btn-secondary" onclick="closeDrawer()">关闭</button>' +
              (isGenerating ? '<button class="btn btn-primary" onclick="submitTechPlanDeepMode(' + tp.id + ')">📤 提交方案</button>' : '') +
            '</div>' +
          '</div>';
        document.getElementById('drawerOverlay').classList.add('show');
        document.getElementById('taskDrawer').classList.add('show');
      } catch (e) {
        showToast('error', '加载失败', e.message);
      }
    }

    function submitTechPlanDeepMode(id) {
      var filesEl = document.getElementById('dm-files');
      var reasonsEl = document.getElementById('dm-reasons');
      var snippetsEl = document.getElementById('dm-snippets');
      var contentEl = document.getElementById('dm-content');

      if (!filesEl || !reasonsEl || !contentEl) return;

      var files = filesEl.value.trim().split('\n').filter(function(f) { return f.trim(); });
      var reasons = reasonsEl.value.trim().split('\n').filter(function(r) { return r.trim(); });
      var snippets = snippetsEl ? snippetsEl.value.trim().split('\n---\n').filter(function(s) { return s.trim(); }) : [];

      if (files.length === 0) {
        showToast('error', '错误', '请至少填写一个检索文件路径');
        return;
      }
      if (reasons.length === 0) {
        showToast('error', '错误', '请填写检索原因');
        return;
      }
      if (!contentEl.value.trim()) {
        showToast('error', '错误', '技术方案内容不能为空');
        return;
      }

      // Build retrieval_log JSON array
      var retrievalLog = [];
      for (var i = 0; i < files.length; i++) {
        var snippet = '';
        if (snippets[i]) {
          snippet = snippets[i].trim();
        } else if (snippets.length === 1 && snippets[0] && files.length > 1) {
          snippet = snippets[0].trim();
        }
        retrievalLog.push({
          file: files[i].trim(),
          reason: reasons[i] ? reasons[i].trim() : (reasons[0] ? reasons[0].trim() : ''),
          snippet: snippet
        });
      }

      api('/api/tech-plans/' + id + '/submit', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({
          content: contentEl.value.trim(),
          retrieval_log: JSON.stringify(retrievalLog)
        })
      }).then(function() {
        closeDrawer();
        showToast('success', '提交成功', '技术方案已提交，等待审核');
        loadTechPlans();
      }).catch(function(e) {
        showToast('error', '提交失败', e.message);
      });
    }

    // Init
    loadAgents();
    loadProjectsForReq();
    loadRequirements();
  </script>
</body>
</html>
