    function renderProjects() {
      var tbody = document.getElementById('projectsTableBody');
      var list = projectPager.list || [];

      if (list.length === 0) {
        tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;padding:40px;color:var(--text-muted)">暂无项目</td></tr>';
      } else {
        var phaseMap = {start: 'Start', alpha: 'Alpha', beta: 'Beta', rc: 'RC'};
        var statusMap = {pending: '未开始', active: '进行中', ended: '已结束'};
        var statusClass = {pending: 'pending', active: 'in_progress', ended: 'done'};

        var html = '';
        for (var i = 0; i < list.length; i++) {
          var p = list[i];
          var desc = p.description && p.description.length > 40 ? p.description.substring(0, 40) + '...' : (p.description || '-');
          html += '<tr>';
          html += '<td>#' + p.id + '</td>';
          html += '<td style="font-weight:500">' + escapeHtml(p.name) + '</td>';
          html += '<td style="color:var(--text-muted);font-size:12px" title="' + escapeHtml(p.description || '') + '">' + escapeHtml(desc) + '</td>';
          html += '<td><a href="javascript:void(0)" onclick="showLocalProject(' + p.id + ')" style="color:var(--accent-blue);text-decoration:none">详情</a></td>';
          html += '<td><span class="code-tag">' + p.code.split('').join('&nbsp;') + '</span></td>';
          html += '<td><span class="phase-tag">' + (phaseMap[p.phase] || p.phase) + '</span></td>';
          html += '<td><span class="status-badge ' + (statusClass[p.status] || p.status) + '">' + (statusMap[p.status] || p.status) + '</span></td>';
          html += '<td style="font-size:12px">' + p.created_at + '</td>';
          html += '<td style="font-size:12px">' + p.updated_at + '</td>';
          html += '<td><button class="btn-icon btn-icon-danger" onclick="showEditProject(' + p.id + ')" title="编辑">✏️</button><button class="btn-icon btn-icon-danger" onclick="deleteProject(' + p.id + ')" title="删除">🗑️</button></td>';
          html += '</tr>';
        }
        tbody.innerHTML = html;
      }

      // 分页
      document.getElementById('projectPagerInfo').textContent = '共 ' + projectPager.total + ' 条';
      var pagerHtml = '';
      if (projectPager.totalPages > 1) {
        if (projectPager.page > 1) pagerHtml += '<button class="btn btn-sm" onclick="goToProjectPage(' + (projectPager.page - 1) + ')">‹</button>';
        for (var pg = 1; pg <= projectPager.totalPages; pg++) {
          if (pg === 1 || pg === projectPager.totalPages || (pg >= projectPager.page - 1 && pg <= projectPager.page + 1)) {
            pagerHtml += '<button class="btn btn-sm' + (pg === projectPager.page ? ' btn-primary' : '') + '" onclick="goToProjectPage(' + pg + ')">' + pg + '</button>';
          } else if (pg === projectPager.page - 2 || pg === projectPager.page + 2) {
            pagerHtml += '<span style="padding:4px">...</span>';
          }
        }
        if (projectPager.page < projectPager.totalPages) pagerHtml += '<button class="btn btn-sm" onclick="goToProjectPage(' + (projectPager.page + 1) + ')">›</button>';
      }
      document.getElementById('projectPager').innerHTML = pagerHtml;
    }

