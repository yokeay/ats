          '<div><div style="font-size:12px;color:var(--text-muted)">负责人</div><div>' + (req.owner_emoji || '') + ' ' + (req.owner_name || '<span style="color:var(--text-muted)">未分配</span>') + '</div></div>' +
          '<div><div style="font-size:12px;color:var(--text-muted)">关联项目</div><div>' + (req.project_name ? '<span class="code-tag" style="font-size:10px;cursor:pointer" onclick="closeDrawer();setTimeout(function(){showProjectDrawer(' + req.project_id + ')},100)">' + (req.project_code || '') + '</span> <span style="cursor:pointer;color:var(--accent-blue)" onclick="closeDrawer();setTimeout(function(){showProjectDrawer(' + req.project_id + ')},100)">' + req.project_name + '</span>' : '<span style="color:var(--text-muted)">-</span>') + '</div></div>' +
          '<div><div style="font-size:12px;color:var(--text-muted)">计划时间</div><div>' + planTime + '</div></div>' +
          '<div><div style="font-size:12px;color:var(--text-muted)">创建时间</div><div style="font-size:13px">' + (req.created_at || '') + '</div></div>' +
          '</div>' +
          '<div style="margin-bottom:16px"><div style="font-size:12px;color:var(--text-muted);margin-bottom:8px">需求描述</div><div style="background:var(--bg-secondary);padding:16px;border-radius:8px;font-size:14px;line-height:1.6">' + (req.description || '无描述') + '</div></div>' +
