    function createProject(e) {
      e.preventDefault();
      var form = e.target;
      var local_items = [];
      var itemsText = form.local_items.value.trim();
      if (itemsText) {
        var lines = itemsText.split('\n');
        for (var i = 0; i < lines.length; i++) {
          var line = lines[i].trim();
          if (!line) continue;
          var colonIdx = line.indexOf(':');
          if (colonIdx > 0) {
            local_items.push({ item_key: line.substring(0, colonIdx).trim(), item_value: line.substring(colonIdx + 1).trim() });
          } else if (line) {
            local_items.push({ item_key: line, item_value: '' });
          }
        }
      }
      api('/api/projects', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({
          name: form.name.value,
          description: form.description.value,
          phase: form.phase.value,
          status: form.status.value,
          work_dir: form.work_dir.value,
          start_command: form.start_command.value,
          local_items: local_items
        })
      }).then(function() {
        closeModal();
        showToast('success', '创建成功', '项目已创建');
        loadProjects();
      }).catch(function(e) {
        showToast('error', '创建失败', e.message);
      });
    }

