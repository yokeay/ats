<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/main.css?v=<%= Date.now() %>">
  <script src="/js/marked.min.js"></script>
</head>
<body>
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-header">
      <div class="logo">📋</div>
      <h1>ATS</h1>
    </div>
    <nav class="sidebar-nav" id="mainNav">
      <div class="nav-section">
        <div class="nav-section-title">工作台</div>
        <div class="nav-item active" onclick="switchView('overview')">
          <span class="icon">👥</span>
          <span class="label">Agent 概览</span>
        </div>
      </div>
      <div class="nav-section">
        <div class="nav-section-title">项目</div>
        <div class="nav-item" onclick="switchView('projects')">
          <span class="icon">📁</span>
          <span class="label">项目管理</span>
        </div>
        <div class="nav-item" onclick="switchView('requirements')">
          <span class="icon">🎯</span>
          <span class="label">需求管理</span>
        </div>
        <div class="nav-item" onclick="switchView('tech')">
          <span class="icon">💻</span>
          <span class="label">技术方案</span>
        </div>
        <div class="nav-item" onclick="switchView('kanban')">
          <span class="icon">📋</span>
          <span class="label">任务管理</span>
        </div>
      </div>
      <div class="nav-section">
        <div class="nav-section-title">系统</div>
        <div class="nav-item" onclick="switchView('system')">
          <span class="icon">⚙️</span>
          <span class="label">系统设置</span>
        </div>
      </div>
    </nav>
  </aside>

  <!-- Main Content -->
  <div class="main-wrapper">
    <header class="header">
      <div class="header-left">
        <h2 class="header-title" id="currentViewTitle">Agent 概览</h2>
      </div>
      <div class="header-right">
        <span class="header-time" id="currentTime"></span>
        <div class="header-status">系统正常</div>
      </div>
    </header>

    <main class="main-content">
      <!-- Agent Overview View -->
      <div id="view-overview" class="view active">
        <div class="agents-grid" id="agentsGrid">
          <div class="empty-state">
            <div class="empty-state-icon">⏳</div>
            <div class="empty-state-title">加载中...</div>
          </div>
        </div>
      </div>

      <!-- Kanban View (Tasks Table) -->
      <div id="view-kanban" class="view">
        <div style="margin-bottom:16px;display:flex;gap:10px;align-items:center;flex-wrap:wrap">
          <button class="btn btn-primary" onclick="showCreateTask()">+ 新建任务</button>
          <div style="display:flex;gap:8px;align-items:center;margin-left:auto;flex-wrap:wrap">
            <select id="taskFilterStatus" class="form-select" style="width:110px" onchange="loadTasks()">
              <option value="">全部状态</option>
              <option value="todo">待执行</option>
              <option value="in_progress">进行中</option>
              <option value="done">已完成</option>
            </select>
            <select id="taskFilterPriority" class="form-select" style="width:100px" onchange="loadTasks()">
              <option value="">全部优先级</option>
              <option value="p0">P0</option>
              <option value="p1">P1</option>
              <option value="p2">P2</option>
            </select>
            <select id="taskFilterAssignee" class="form-select" style="width:130px" onchange="loadTasks()">
              <option value="">全部负责人</option>
            </select>
          </div>
        </div>
        <div class="card">
          <div class="card-body" style="padding:0">
            <table class="data-table">
              <thead>
                <tr>
                  <th style="width:60px">ID</th>
                  <th>关联需求</th>
                  <th>任务名称</th>
                  <th style="width:80px">优先级</th>
                  <th style="width:120px">负责人</th>
                  <th style="width:100px">状态</th>
                  <th style="width:80px">操作</th>
                </tr>
              </thead>
              <tbody id="tasksTableBody">
                <tr><td colspan="7" style="text-align:center;padding:40px;color:var(--text-muted)">加载中...</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Task Detail Drawer -->
      <div class="drawer-overlay" id="drawerOverlay" onclick="closeDrawer()"></div>
      <div class="drawer" id="taskDrawer">
        <div class="drawer-header">
          <h3 id="drawerTitle">任务详情</h3>
          <button class="drawer-close" onclick="closeDrawer()">×</button>
        </div>
        <div class="drawer-body" id="drawerBody"></div>
      </div>

      <!-- Local Project Drawer -->
      <div class="drawer-overlay" id="lpDrawerOverlay" onclick="closeLocalProjectDrawer()"></div>
      <div class="drawer" id="localProjectDrawer" style="width:560px">
        <div class="drawer-header">
          <h3 id="lpDrawerTitle">本地项目</h3>
          <button class="drawer-close" onclick="closeLocalProjectDrawer()">×</button>
        </div>
        <div class="drawer-body" id="lpDrawerBody"></div>
      </div>

      <!-- Approval View -->
      <!-- Tech Design View -->
      <div id="view-tech" class="view">
        <div style="margin-bottom:16px;display:flex;gap:8px;flex-wrap:wrap">
          <input type="text" id="tpSearch" class="form-input" style="flex:1;max-width:200px" placeholder="搜索技术方案..." onkeyup="if(event.key==='Enter')loadTechPlans()">
          <select id="tpReqFilter" class="form-select" style="width:180px" onchange="loadTechPlans()">
            <option value="">全部需求</option>
          </select>
          <select id="tpCatFilter" class="form-select" style="width:120px" onchange="loadTechPlans()">
            <option value="">全部分类</option>
            <option value="ui">UI原型</option>
            <option value="frontend">前端</option>
            <option value="backend">后端</option>
            <option value="test">测试</option>
            <option value="ops">运维</option>
          </select>
          <select id="tpAuditFilter" class="form-select" style="width:130px" onchange="loadTechPlans()">
            <option value="">全部审核</option>
            <option value="pending">待审核</option>
            <option value="pass">通过</option>
            <option value="reject">驳回</option>
          </select>
          <select id="tpStatusFilter" class="form-select" style="width:130px" onchange="loadTechPlans()">
            <option value="">全部状态</option>
            <option value="generating">生成中</option>
            <option value="review">待评审</option>
            <option value="in_progress">进行中</option>
            <option value="done">已完成</option>
          </select>
          <button class="btn btn-secondary" onclick="loadTechPlans()">🔍 搜索</button>
          <button class="btn btn-primary" onclick="showCreateTechPlan()">+ 新建方案</button>
        </div>
        <div class="card">
          <div class="card-body" style="padding:0">
            <table class="data-table">
              <thead>
                <tr>
                  <th style="width:50px">ID</th>
                  <th style="width:120px">项目</th>
                  <th style="width:160px">需求</th>
                  <th style="width:70px">类别</th>
                  <th style="width:70px">阶段</th>
                  <th style="width:100px">作者</th>
                  <th style="width:60px">版本</th>
                  <th style="width:90px">审核状态</th>
                  <th style="width:90px">评审状态</th>
                  <th style="width:140px">更新时间</th>
                  <th style="width:200px">操作</th>
                </tr>
              </thead>
              <tbody id="techPlansTableBody">
                <tr><td colspan="11" style="text-align:center;padding:40px;color:var(--text-muted)">加载中...</td></tr>
              </tbody>
            </table>
            <div id="techPlansPagination" style="padding:16px;display:flex;justify-content:center;align-items:center;gap:8px"></div>
          </div>
        </div>
      </div>

      <!-- Requirements View -->
      <div id="view-requirements" class="view">
        <div style="margin-bottom:16px;display:flex;gap:8px">
          <input type="text" id="reqSearch" class="form-input" style="flex:1" placeholder="搜索需求名称、描述..." onkeyup="if(event.key==='Enter')searchRequirements()">
          <select id="reqProjectFilter" class="form-select" style="width:150px" onchange="searchRequirements()">
            <option value="">全部项目</option>
          </select>
          <select id="reqStatusFilter" class="form-select" style="width:130px" onchange="searchRequirements()">
            <option value="">全部状态</option>
            <option value="review">待评审</option>
            <option value="in_progress">进行中</option>
            <option value="done">已完成</option>
          </select>
          <select id="reqSort" class="form-select" style="width:120px" onchange="searchRequirements()">
            <option value="desc">最新创建</option>
            <option value="asc">最早创建</option>
          </select>
          <button class="btn btn-secondary" onclick="searchRequirements()">🔍 搜索</button>
          <button class="btn btn-primary" onclick="showCreateRequirement()">+ 新建</button>
        </div>
        <div class="card">
          <div class="card-body" style="padding:0">
            <table class="data-table">
              <thead>
                <tr>
                  <th style="width:50px">ID</th>
                  <th style="width:150px">需求名称</th>
                  <th style="width:120px">关联项目</th>
                  <th style="width:60px">优先级</th>
                  <th style="width:100px">状态</th>
                  <th style="width:100px">负责人</th>
                  <th style="width:180px">计划时间</th>
                  <th style="width:140px">创建时间</th>
                  <th style="width:80px;white-space:nowrap">操作</th>
                </tr>
              </thead>
              <tbody id="requirementsTableBody">
                <tr><td colspan="9" style="text-align:center;padding:40px;color:var(--text-muted)">加载中...</td></tr>
              </tbody>
            </table>
          </div>
          <div class="card-footer" style="padding:12px 16px;display:flex;justify-content:space-between;align-items:center">
            <div id="reqPagerInfo" style="font-size:12px;color:var(--text-muted)"></div>
            <div id="reqPager" style="display:flex;gap:4px"></div>
          </div>
        </div>
      </div>

      <!-- Projects View -->
      <div id="view-projects" class="view">
        <div style="margin-bottom:16px;display:flex;gap:8px">
          <input type="text" id="projectSearch" class="form-input" style="flex:1" placeholder="搜索项目名称、编码、描述..." onkeyup="if(event.key==='Enter')searchProjects()">
          <select id="projectSort" class="form-select" style="width:120px" onchange="searchProjects()">
            <option value="desc">最新创建</option>
            <option value="asc">最早创建</option>
          </select>
          <button class="btn btn-secondary" onclick="searchProjects()">🔍 搜索</button>
          <button class="btn btn-primary" onclick="showCreateProject()">+ 新建</button>
        </div>
        <div class="card">
          <div class="card-body" style="padding:0">
            <table class="data-table">
              <thead>
                <tr>
                  <th style="width:50px">ID</th>
                  <th style="width:120px">项目名称</th>
                  <th style="width:200px">项目描述</th>
                  <th style="width:70px">本地项目</th>
                  <th style="width:80px">编码</th>
                  <th style="width:60px">阶段</th>
                  <th style="width:70px">状态</th>
                  <th style="width:140px">创建时间</th>
                  <th style="width:140px">修改时间</th>
                  <th style="width:80px;white-space:nowrap">操作</th>
                </tr>
              </thead>
              <tbody id="projectsTableBody">
                <tr><td colspan="10" style="text-align:center;padding:40px;color:var(--text-muted)">加载中...</td></tr>
              </tbody>
            </table>
          </div>
          <div class="card-footer" style="padding:12px 16px;display:flex;justify-content:space-between;align-items:center">
            <div id="projectPagerInfo" style="font-size:12px;color:var(--text-muted)"></div>
            <div id="projectPager" style="display:flex;gap:4px"></div>
          </div>
        </div>
      </div>

      <!-- System View -->
      <div id="view-system" class="view">
        <!-- 系统统计 -->
        <div class="stats-grid" id="statsGrid"></div>

        <!-- Agent 列表 -->
        <div style="margin-top:24px">
          <div class="card">
            <div class="card-header">
              <div class="card-title"><span>👥</span> Agent 列表</div>
              <span class="card-subtitle">团队成员及工作状态</span>
            </div>
            <div class="card-body" style="padding:0">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>成员</th>
                    <th>角色</th>
                    <th>状态</th>
                    <th>当前任务</th>
                    <th>工作量</th>
                  </tr>
                </thead>
                <tbody id="agentListBody">
                  <tr><td colspan="5" style="text-align:center;padding:30px;color:var(--text-muted)">加载中...</td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- 系统信息 -->
        <div style="margin-top:24px">
          <div class="card">
            <div class="card-header">
              <div class="card-title"><span>🖥️</span> 系统信息</div>
            </div>
            <div class="card-body" style="padding:0">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>项目</th>
                    <th>值</th>
                  </tr>
                </thead>
                <tbody id="systemInfoBody">
                  <tr><td colspan="2" style="text-align:center;padding:30px;color:var(--text-muted)">加载中...</td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Modal -->
  <div class="modal-overlay" id="modalOverlay">
    <div class="modal">
      <div class="modal-header">
        <h3 class="modal-title" id="modalTitle">标题</h3>
        <button class="modal-close" onclick="closeModal()">×</button>
      </div>
      <div class="modal-body" id="modalBody"></div>
      <div class="modal-footer" id="modalFooter"></div>
    </div>
  </div>

  <!-- Toast Container -->
  <div class="toast-container" id="toastContainer"></div>

  <script>
    // Global error handler
    window.addEventListener('error', function(e) {
      console.error('Page error:', e.message, 'at', e.filename, ':', e.lineno);
    });

    // Global state
    var agents = [];
    var requirements = [];
    var currentView = 'overview';
    var globalSSE = null; // 全局 SSE 连接
    var loadedAgents = false; // 是否已加载过 Agent 数据

    // Update time
    setInterval(function() {
      document.getElementById('currentTime').textContent = new Date().toLocaleTimeString('zh-CN', {hour:'2-digit',minute:'2-digit'});
    }, 1000);
    document.getElementById('currentTime').textContent = new Date().toLocaleTimeString('zh-CN', {hour:'2-digit',minute:'2-digit'});

    // 初始化全局 SSE
    function initGlobalSSE() {
      if (globalSSE) return;

      globalSSE = new EventSource('/api/system/stream');
      globalSSE.onmessage = function(e) {
        try {
          var data = JSON.parse(e.data);

          // 处理日志更新 (data.agentId 存在且有 data.logs)
          if (data.agentId && data.logs) {
            var container = document.getElementById('logs-' + data.agentId);
            if (container) {
              var html = '';
              var logs = data.logs || [];
              for (var i = 0; i < Math.min(logs.length, 10); i++) {
                var log = logs[i];
                html += '<div class="log-entry"><span class="log-time">' + (log.created_at ? log.created_at.split(' ')[1] : '') + '</span>' + log.message + '</div>';
              }
              container.innerHTML = html || '<div style="color:var(--text-muted);padding:8px">暂无日志</div>';
            }
          }

          // 处理工作开始
          if (data.type === 'work_started') {
            showToast('success', '任务开始', data.current_detail || 'Agent 开始执行任务');
            loadAgents();
          }

          // 处理进度更新（实时）
          if (data.type === 'progress_update' && data.agentId) {
            var agentCard = document.querySelector('.agent-card[onclick*="' + data.agentId + '"]');
            if (agentCard) {
              var progressFill = agentCard.querySelector('.progress-fill');
              var progressLabel = agentCard.querySelector('.progress-label span:last-child');
              if (progressFill) progressFill.style.width = data.progress + '%';
              if (progressLabel) progressLabel.textContent = data.progress + '%';
            }
          }

          // 处理工作完成
          if (data.type === 'work_completed') {
            showToast('success', '任务完成', (data.agent_name || 'Agent') + ' 已完成任务');
            loadAgents();
            loadAgentLogs(data.agentId);
          }

          // 处理技术方案审核通过通知
          if (data.type === 'tech_plan_approved') {
            var catNames = { frontend: '前端', backend: '后端', test: '测试', ops: '运维' };
            showToast('success', '技术方案通过', catNames[data.category] + ' Agent 已收到通知，将开始规划任务');
            loadAgents();
          }

          // 本地项目启动/停止
          if (data.type === 'local_project_started') {
            showToast('success', '项目已启动', '运行于 ' + window.location.hostname + ':' + data.port);
          }
          if (data.type === 'local_project_stopped') {
            showToast('info', '项目已停止');
          }

          // 工作状态变化时刷新 Agent 和日志
          if (data.type === 'work_started' || data.type === 'work_completed') {
            loadAgents();
          }
        } catch (err) {}
      };

      globalSSE.onerror = function() {
        console.warn('SSE Connection lost, retrying in 5s...');
        globalSSE.close();
        globalSSE = null;
        setTimeout(initGlobalSSE, 5000);
      };
    }

    // Switch view
    function switchView(view) {
      currentView = view;
      // Hide all views
      var views = document.querySelectorAll('.view');
      for (var i = 0; i < views.length; i++) {
        views[i].classList.remove('active');
      }
      // Show selected view
      var targetView = document.getElementById('view-' + view);
      if (targetView) {
        targetView.classList.add('active');
      }
      // Update nav
      var navItems = document.querySelectorAll('.nav-item');
      for (var i = 0; i < navItems.length; i++) {
        navItems[i].classList.remove('active');
        if (navItems[i].getAttribute('onclick') === "switchView('" + view + "')") {
          navItems[i].classList.add('active');
        }
      }
      // Update title
      var titles = {
        overview: 'Agent 概览',
        kanban: '任务管理',
        projects: '项目管理',
        requirements: '需求管理',
        tech: '技术方案',
        system: '系统设置'
      };
      document.getElementById('currentViewTitle').textContent = titles[view] || view;

      // 根据视图加载数据
      if (view === 'system') {
        loadSystemInfo();
      } else if (view === 'kanban') {
        loadTasks();
      } else if (view === 'overview') {
        loadAgents();
      } else if (view === 'projects') {
        loadProjects();
      } else if (view === 'requirements') {
        loadRequirements();
      } else if (view === 'tech') {
        loadTechPlans();
      }
    }

    // API Helper
    async function api(url, options) {
      options = options || {};
      var res = await fetch(url, options);
      var data = await res.json();
      if (data.code !== 0) throw new Error(data.message);
      return data.data;
    }

    // Toast
    function showToast(type, title, message) {
      var icons = {success:'✓', error:'✗', warning:'⚠', info:'ℹ'};
      var toast = document.createElement('div');
      toast.className = 'toast ' + type;
      toast.innerHTML = '<span class="toast-icon">' + icons[type] + '</span><div class="toast-content"><div class="toast-title">' + title + '</div><div class="toast-message">' + message + '</div></div>';
      document.getElementById('toastContainer').appendChild(toast);
      setTimeout(function() { toast.remove(); }, 1000);
    }

    // Modal
    function showModal(title, body, footer, width) {
      document.getElementById('modalTitle').textContent = title;
      document.getElementById('modalBody').innerHTML = body;
      document.getElementById('modalFooter').innerHTML = footer || '';
      var modal = document.getElementById('modalOverlay');
      var content = modal.querySelector('.modal');
      if (width) content.style.maxWidth = width;
      else content.style.maxWidth = '500px';
      modal.classList.add('show');
    }

    function closeModal() {
      var modal = document.getElementById('modalOverlay');
      modal.classList.remove('show');
      var content = modal.querySelector('.modal');
      if (content) content.style.maxWidth = '500px';
    }

    // Load Agents
    async function loadAgents() {
      try {
        agents = await api('/api/agents');
        // 同时加载所有日志
        var allLogs = await api('/api/agents/logs/all');
        agentLogs = allLogs;
        renderAgents();
        updatePendingApprovals();
        loadedAgents = true;
      } catch (e) {
        console.error('Failed to load agents:', e);
      }
    }

    // 存储所有日志
    var agentLogs = [];

    function renderAgents() {
      var grid = document.getElementById('agentsGrid');
      if (agents.length === 0) {
        grid.innerHTML = '<div class="empty-state"><div class="empty-state-icon">👥</div><div class="empty-state-title">暂无 Agent</div></div>';
        return;
      }
      var html = '';
      for (var i = 0; i < agents.length; i++) {
        var agent = agents[i];
        var statusText = agent.status === 'idle' ? '空闲' : agent.status === 'busy' ? '工作中' : '已暂停';

        // 获取该 Agent 的日志
        var logsHtml = '';
        var agentLogItems = agentLogs.filter(function(l) { return l.agent_id === agent.id; });
        if (agentLogItems.length === 0) {
          logsHtml = '<div style="color:var(--text-muted);padding:8px">暂无日志</div>';
        } else {
          for (var j = 0; j < Math.min(agentLogItems.length, 5); j++) {
            var log = agentLogItems[j];
            var time = log.created_at ? log.created_at.split(' ')[1] : '';
            logsHtml += '<div class="log-entry"><span class="log-time">' + time + '</span>' + log.message + '</div>';
          }
        }

        html += '<div class="agent-card' + (agent.status === 'pause' ? ' suspended' : '') + '" onclick="showAgentDetail(\'' + agent.id + '\')">';
        html += '<div class="agent-header"><div class="agent-avatar" style="background:' + agent.color + '30;">' + agent.emoji + '</div>';
        html += '<div class="agent-info"><h3>' + agent.name + ' <span style="font-size:12px;font-weight:normal;color:var(--text-muted)">(' + agent.role + ')</span></h3></div></div>';
        html += '<span class="status-badge ' + agent.status + '">' + statusText + '</span>';
        html += '<div class="progress-wrapper"><div class="progress-label"><span>' + (agent.current_action || '空闲中') + '</span><span>' + (agent.progress || 0) + '%</span></div>';
        html += '<div class="progress-bar"><div class="progress-fill" style="width:' + (agent.progress || 0) + '%"></div></div>';
        html += '<div style="font-size:12px;color:var(--text-muted);margin-top:6px">' + (agent.current_detail || '') + '</div></div>';
        html += '<div class="log-container" id="logs-' + agent.id + '">' + logsHtml + '</div>';
        html += '</div>';
      }
      grid.innerHTML = html;
    }

    // Load Tasks for Kanban (Table View)
    async function loadTasks() {
      try {
        var params = new URLSearchParams();
        var statusVal = document.getElementById('taskFilterStatus').value;
        var priorityVal = document.getElementById('taskFilterPriority').value;
        var assigneeVal = document.getElementById('taskFilterAssignee').value;
        if (statusVal) params.append('status', statusVal);
        if (priorityVal) params.append('priority', priorityVal);
        if (assigneeVal) params.append('assignee_id', assigneeVal);

        var tasksData = await api('/api/tasks?' + params.toString());
        var reqsData = await api('/api/requirements');
        kanbanTasks = tasksData.list || tasksData;
        kanbanRequirements = reqsData.list || reqsData;

        // 构建负责人筛选下拉（只构建一次）
        var assigneeSelect = document.getElementById('taskFilterAssignee');
        if (assigneeSelect.options.length <= 1) {
          var currentVal = assigneeSelect.value;
          for (var i = 0; i < agents.length; i++) {
            var opt = document.createElement('option');
            opt.value = agents[i].id;
            opt.textContent = agents[i].emoji + ' ' + agents[i].name;
            assigneeSelect.appendChild(opt);
          }
          assigneeSelect.value = currentVal;
        }

        renderTasksTable();
      } catch (e) {
        console.error('Failed to load tasks:', e);
      }
    }

    var kanbanTasks = [];
    var kanbanRequirements = [];

    function renderTasksTable() {
      var tbody = document.getElementById('tasksTableBody');
      if (kanbanTasks.length === 0) {
        tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:40px;color:var(--text-muted)">暂无任务，点击上方按钮新建</td></tr>';
        return;
      }

      // Step 1: 按 requirementId 分组
      var groups = {};
      for (var i = 0; i < kanbanTasks.length; i++) {
        var t = kanbanTasks[i];
        var key = t.requirement_id || '__none__';
        if (!groups[key]) {
          groups[key] = {
            requirement_id: t.requirement_id,
            requirement_title: t.requirement_title || '无关联需求',
            tasks: []
          };
        }
        groups[key].tasks.push(t);
      }

      // Step 2: 生成树形HTML
      var html = '';
      var groupKeys = Object.keys(groups);

      for (var g = 0; g < groupKeys.length; g++) {
        var group = groups[groupKeys[g]];
        var groupId = 'req-' + (group.requirement_id || 'none') + '-' + g;

        // 父行：关联需求（默认收起），用 data-req-name 保存原始值供 toggle 使用
        html += '<tr data-req-name="' + escapeHtml(group.requirement_title) + '" data-req-count="' + group.tasks.length + '" data-req-state="collapsed" style="background:var(--bg-secondary);cursor:pointer" onclick="toggleReqGroup(\'' + groupId + '\', this)">';
        html += '<td style="width:50px"><span id="' + groupId + '-icon" style="font-size:11px;margin-right:2px">▶</span>#</td>';
        html += '<td><span style="color:var(--accent-blue);font-weight:600">' + group.requirement_title + '</span>';
        html += ' <span style="color:var(--text-muted);font-size:12px">（' + group.tasks.length + ' 个任务）</span></td>';
        html += '<td colspan="5"><span id="' + groupId + '-hint" style="color:var(--text-muted);font-size:12px">点击展开查看</span></td>';
        html += '</tr>';

        // 子行：每条任务（默认隐藏）
        for (var k = 0; k < group.tasks.length; k++) {
          var task = group.tasks[k];
          html += buildTaskRow(task, groupId);
        }
      }

      tbody.innerHTML = html;
    }

    function toggleReqGroup(groupId, headerRow) {
      var icon = document.getElementById(groupId + '-icon');
      var hint = document.getElementById(groupId + '-hint');
      var taskRows = document.querySelectorAll('tr[data-req-group="' + groupId + '"]');
      var state = headerRow.dataset.reqState;

      if (state === 'collapsed') {
        // 展开
        icon.textContent = '▼';
        hint.style.display = 'none';
        taskRows.forEach(function(r) { r.style.display = ''; });
        headerRow.dataset.reqState = 'expanded';
      } else {
        // 收起
        icon.textContent = '▶';
        hint.style.display = '';
        taskRows.forEach(function(r) { r.style.display = 'none'; });
        headerRow.dataset.reqState = 'collapsed';
      }
    }

    function buildTaskRow(task, reqGroup) {
      var statusText = {todo:'待执行', in_progress:'进行中', done:'已完成'}[task.status] || task.status;
      var statusClass = task.status;
      var hasResult = task.has_result ? '📎 ' : '';
      var hiddenStyle = reqGroup ? 'style="display:none" data-req-group="' + reqGroup + '"' : '';

      var html = '<tr ' + hiddenStyle + '>';
      html += '<td>#' + task.id + '</td>';
      html += '<td>' + (task.requirement_title ? '<span style="color:var(--accent-blue);cursor:pointer" onclick="viewRequirement(' + task.requirement_id + ')">' + task.requirement_title + '</span>' : '<span style="color:var(--text-muted)">-</span>') + '</td>';
      html += '<td><span style="cursor:pointer;color:var(--accent-blue)" onclick="showTaskDrawer(' + task.id + ')">' + hasResult + task.title + '</span></td>';
      html += '<td><span class="priority-tag ' + task.priority + '">' + task.priority.toUpperCase() + '</span></td>';
      html += '<td>' + (task.assignee_emoji || '') + ' ' + (task.assignee_name || '<span style="color:var(--text-muted)">未分配</span>') + '</td>';
      html += '<td><span class="status-badge ' + statusClass + '">' + statusText + '</span></td>';
      html += '<td>';
      html += '<button class="btn btn-sm btn-secondary" onclick="showTaskDrawer(' + task.id + ')" style="margin-right:4px">详情</button>';
      html += '<button class="btn btn-sm btn-danger-outline" onclick="deleteTask(' + task.id + ')" style="color:var(--danger);background:transparent;border:1px solid var(--danger);padding:3px 8px;border-radius:4px;font-size:12px;cursor:pointer">删除</button>';
      html += '</td>';
      html += '</tr>';
      return html;
    }

    // 新建任务
    function showCreateTask() {
      var agentOptions = '<option value="">未分配</option>';
      for (var i = 0; i < agents.length; i++) {
        agentOptions += '<option value="' + agents[i].id + '">' + agents[i].emoji + ' ' + agents[i].name + ' (' + agents[i].role + ')</option>';
      }
      var reqOptions = '<option value="">无关联需求</option>';
      for (var i = 0; i < kanbanRequirements.length; i++) {
        reqOptions += '<option value="' + kanbanRequirements[i].id + '">' + kanbanRequirements[i].title + '</option>';
      }
      showModal('新建任务',
        '<form onsubmit="createTask(event)"><div class="form-group"><label class="form-label">任务标题</label><input name="title" class="form-input" required placeholder="请输入任务标题"></div><div class="form-group"><label class="form-label">任务描述</label><textarea name="description" class="form-textarea" placeholder="请描述任务内容"></textarea></div><div class="form-group"><label class="form-label">关联需求</label><select name="requirement_id" class="form-select">' + reqOptions + '</select></div><div class="form-group"><label class="form-label">分配给</label><select name="assignee_id" class="form-select">' + agentOptions + '</select></div><div class="form-group"><label class="form-label">优先级</label><select name="priority" class="form-select"><option value="p0">P0 - 紧急</option><option value="p1">P1 - 高</option><option value="p2" selected>P2 - 中</option></select></div></form>',
        '<button type="button" class="btn btn-secondary" onclick="closeModal()">取消</button><button type="submit" class="btn btn-primary">创建任务</button>'
      );
    }

    function createTask(e) {
      e.preventDefault();
      var form = e.target;
      api('/api/tasks', {
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify({
          title: form.title.value,
          description: form.description.value,
          requirement_id: form.requirement_id.value || null,
          assignee_id: form.assignee_id.value || null,
          priority: form.priority.value
        })
      }).then(function() {
        closeModal();
        showToast('success', '创建成功', '任务已创建');
        loadTasks();
      }).catch(function(e) { showToast('error', '创建失败', e.message); });
    }

    // 任务详情抽屉
    async function showTaskDrawer(taskId) {
      try {
        var task = await api('/api/tasks/' + taskId);
        var results = await api('/api/tasks/' + taskId + '/results');

        var statusMap = {todo:'待执行', in_progress:'进行中', done:'已完成'};
        var statusText = statusMap[task.status] || task.status;

        var resultHtml = '';
        if (results.length > 0) {
          resultHtml = '<div style="margin-top:24px"><h4 style="margin-bottom:12px">📎 任务结果</h4>';
          for (var i = 0; i < results.length; i++) {
            var r = results[i];
            if (r.content_type === 'html') {
              resultHtml += '<div style="border:1px solid var(--border-color);border-radius:8px;padding:16px;background:var(--bg-primary)"><div style="font-size:12px;color:var(--text-muted);margin-bottom:8px">' + r.file_name + '</div><iframe srcdoc="' + encodeURIComponent(r.content) + '" style="width:100%;height:300px;border:none;background:white;border-radius:4px"></iframe></div>';
            } else if (r.content_type === 'code') {
              resultHtml += '<div style="border:1px solid var(--border-color);border-radius:8px;padding:16px;background:var(--bg-primary)"><div style="font-size:12px;color:var(--text-muted);margin-bottom:8px">' + r.file_name + '</div><pre style="background:#1e1e1e;color:#d4d4d4;padding:16px;border-radius:8px;overflow-x:auto;font-size:12px;max-height:400px">' + escapeHtml(r.content) + '</pre></div>';
            } else {
              resultHtml += '<div style="border:1px solid var(--border-color);border-radius:8px;padding:16px;background:var(--bg-primary)"><pre style="white-space:pre-wrap;font-size:13px">' + escapeHtml(r.content) + '</pre></div>';
            }
          }
          resultHtml += '</div>';
        }

        document.getElementById('drawerTitle').textContent = '任务 #' + task.id + ': ' + task.title;
        document.getElementById('drawerBody').innerHTML =
          '<div style="padding:20px">' +
          '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">' +
            '<div style="font-size:16px;font-weight:600">' + task.title + '</div>' +
            '<div style="display:flex;gap:8px">' +
              '<button class="btn btn-sm btn-secondary" onclick="showEditTask(' + task.id + ')">编辑</button>' +
              '<button class="btn btn-sm" style="background:var(--danger);color:white;border:none" onclick="deleteTask(' + task.id + ')">删除</button>' +
            '</div>' +
          '</div>' +
          '<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px">' +
          '<div><div style="font-size:12px;color:var(--text-muted)">状态</div><div><select onchange="updateTaskField(' + task.id + ', \'status\', this.value)" style="background:var(--bg-secondary);border:1px solid var(--border-color);color:var(--text-primary);padding:6px 10px;border-radius:6px;cursor:pointer">' +
            '<option value="todo"' + (task.status==='todo'?' selected':'') + '>待执行</option>' +
            '<option value="in_progress"' + (task.status==='in_progress'?' selected':'') + '>进行中</option>' +
            '<option value="done"' + (task.status==='done'?' selected':'') + '>已完成</option>' +
          '</select></div></div>' +
          '<div><div style="font-size:12px;color:var(--text-muted)">优先级</div><div><span class="priority-tag ' + task.priority + '">' + task.priority.toUpperCase() + '</span></div></div>' +
          '<div><div style="font-size:12px;color:var(--text-muted)">负责人</div><div>' + (task.assignee_emoji || '') + ' ' + (task.assignee_name || '未分配') + '</div></div>' +
          '<div><div style="font-size:12px;color:var(--text-muted)">创建时间</div><div style="font-size:13px">' + task.created_at + '</div></div>' +
          '</div>' +
          (task.requirement_title ? '<div style="margin-bottom:16px"><div style="font-size:12px;color:var(--text-muted)">关联需求</div><div><span style="color:var(--accent-blue);cursor:pointer" onclick="viewRequirement(' + task.requirement_id + ')">' + task.requirement_title + '</span></div></div>' : '') +
          '<div style="margin-bottom:16px"><div style="font-size:12px;color:var(--text-muted);margin-bottom:8px">任务描述</div><div style="background:var(--bg-secondary);padding:16px;border-radius:8px;font-size:14px;line-height:1.6">' + (task.description || '无') + '</div></div>' +
          resultHtml +
          '</div>';

        document.getElementById('drawerOverlay').classList.add('show');
        document.getElementById('taskDrawer').classList.add('show');
      } catch (e) {
        showToast('error', '加载失败', e.message);
      }
    }

    function closeDrawer() {
      document.getElementById('drawerOverlay').classList.remove('show');
      document.getElementById('taskDrawer').classList.remove('show');
    }

    function openLocalProjectDrawer() {
      document.getElementById('lpDrawerOverlay').classList.add('show');
      document.getElementById('localProjectDrawer').classList.add('show');
    }

    function closeLocalProjectDrawer() {
      document.getElementById('lpDrawerOverlay').classList.remove('show');
      document.getElementById('localProjectDrawer').classList.remove('show');
    }

    async function showLocalProject(projectId) {
      try {
        var lp = await api('/api/local-projects/' + projectId);
        document.getElementById('lpDrawerTitle').textContent = '本地项目: ' + (lp.project_name || '未命名');
        var statusLabel = { running: '运行中', stopped: '已停止' };
        var statusClass = { running: 'running', stopped: 'stopped' };
        var itemsHtml = '';
        if (lp.items && lp.items.length > 0) {
          itemsHtml = '<table style="width:100%;border-collapse:collapse;margin-top:12px"><thead><tr style="border-bottom:1px solid var(--border-color)"><th style="text-align:left;padding:8px 4px;color:var(--text-muted);font-weight:normal;font-size:12px">字段</th><th style="text-align:left;padding:8px 4px;color:var(--text-muted);font-weight:normal;font-size:12px">值</th></tr></thead><tbody>';
          for (var ki = 0; ki < lp.items.length; ki++) {
            var item = lp.items[ki];
            itemsHtml += '<tr style="border-bottom:1px solid var(--border-color)"><td style="padding:8px 4px;font-weight:500">' + escapeHtml(item.item_key) + '</td><td style="padding:8px 4px;color:var(--text-muted);word-break:break-all">' + escapeHtml(item.item_value) + '</td></tr>';
          }
          itemsHtml += '</tbody></table>';
        } else {
          itemsHtml = '<div style="color:var(--text-muted);font-size:13px;padding:8px 0">暂无配置项</div>';
        }
        var html = '<div style="display:flex;flex-direction:column;gap:16px">';
        html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">';
        html += '<div class="form-group" style="margin:0"><label class="form-label">项目名称</label><div style="padding:8px 12px;background:var(--bg-main);border-radius:8px;border:1px solid var(--border-color);font-size:14px">' + escapeHtml(lp.project_name || '未命名') + '</div></div>';
        html += '<div class="form-group" style="margin:0"><label class="form-label">运行地址</label><div style="padding:8px 12px;background:var(--bg-main);border-radius:8px;border:1px solid var(--border-color);font-size:14px;color:' + (lp.port ? 'var(--accent-green)' : 'var(--text-muted)') + '">' + (lp.port ? window.location.hostname + ':' + lp.port : '未运行') + '</div></div>';
        html += '</div>';
        html += '<div class="form-group" style="margin:0"><label class="form-label">启动命令</label><input class="form-input" id="lpCommand" value="' + escapeHtml(lp.start_command || '') + '" placeholder="如: node server.js"></div>';
        html += '<div class="form-group" style="margin:0"><label class="form-label">工作目录</label><input class="form-input" id="lpWorkDir" value="' + escapeHtml(lp.work_dir || '') + '" placeholder="如: /home/myprojects/JavaScript/myapp"></div>';
        html += '<div style="display:flex;align-items:center;gap:12px">';
        html += '<span class="status-badge ' + (statusClass[lp.status] || 'stopped') + '">' + (statusLabel[lp.status] || '已停止') + '</span>';
        if (lp.status === 'running') {
          html += '<a href="http://' + window.location.hostname + ':' + lp.port + '" target="_blank" class="btn btn-secondary" style="text-decoration:none">访问项目</a>';
          html += '<button class="btn btn-danger" onclick="lpStopProject(' + projectId + ')">停止</button>';
        } else {
          html += '<button class="btn btn-primary" onclick="lpStartProject(' + projectId + ')">启动项目</button>';
        }
        html += '<button class="btn btn-secondary" onclick="lpSaveProject(' + projectId + ')">保存配置</button>';
        html += '</div>';
        html += '<div style="border-top:1px solid var(--border-color);padding-top:12px">';
        html += '<div style="margin-bottom:8px"><span style="font-weight:500;font-size:13px">配置项</span></div>';
        html += itemsHtml;
        html += '</div>';
        html += '</div>';
        document.getElementById('lpDrawerBody').innerHTML = html;
        openLocalProjectDrawer();
      } catch (e) {
        showToast('error', '加载失败', e.message);
      }
    }

    async function lpSaveProject(projectId) {
      var start_command = document.getElementById('lpCommand').value;
      var work_dir = document.getElementById('lpWorkDir').value;
      try {
        await api('/api/local-projects/' + projectId, { method: 'PATCH', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ start_command, work_dir }) });
        showToast('success', '保存成功');
      } catch (e) {
        showToast('error', '保存失败', e.message);
      }
    }

    async function lpStartProject(projectId) {
      try {
        await lpSaveProject(projectId);
        var btn = document.querySelector('.btn-primary');
        if (btn) { btn.disabled = true; btn.textContent = '启动中...'; }
        await api('/api/local-projects/' + projectId + '/start', { method: 'POST', headers: {'Content-Type':'application/json'}, body: '{}' });
        showToast('success', '项目启动中', '请等待2-3秒后刷新端口信息');
        setTimeout(function() { showLocalProject(projectId); }, 3000);
      } catch (e) {
        showToast('error', '启动失败', e.message);
      }
    }

    async function lpStopProject(projectId) {
      try {
        await api('/api/local-projects/' + projectId + '/stop', { method: 'POST', headers: {'Content-Type':'application/json'}, body: '{}' });
        showToast('success', '已停止');
        showLocalProject(projectId);
      } catch (e) {
        showToast('error', '停止失败', e.message);
      }
    }

    async function lpAddItem(projectId) {
      var key = prompt('请输入字段名称（如：仓库地址）：');
      if (!key) return;
      var value = prompt('请输入字段值（如：https://github.com/xxx）：') || '';
      try {
        await api('/api/local-projects/' + projectId + '/items', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ item_key: key, item_value: value }) });
        showLocalProject(projectId);
      } catch (e) {
        showToast('error', '添加失败', e.message);
      }
    }

    async function lpDeleteItem(projectId, itemId) {
      try {
        await api('/api/local-projects/' + projectId + '/items/' + itemId, { method: 'DELETE' });
        showLocalProject(projectId);
      } catch (e) {
        showToast('error', '删除失败', e.message);
      }
    }

    // 快速更新任务单个字段
    async function updateTaskField(taskId, field, value) {
      try {
        var body = {};
        body[field] = value;
        await api('/api/tasks/' + taskId, { method: 'PATCH', headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
        showToast('success', '更新成功');
        loadTasks();
        showTaskDrawer(taskId);
      } catch (e) {
        showToast('error', '更新失败', e.message);
      }
    }

    // 编辑任务
    async function showEditTask(taskId) {
      try {
        var task = await api('/api/tasks/' + taskId);
        var agentOptions = '<option value="">未分配</option>';
        for (var i = 0; i < agents.length; i++) {
          agentOptions += '<option value="' + agents[i].id + '"' + (agents[i].id === task.assignee_id ? ' selected' : '') + '>' + agents[i].emoji + ' ' + agents[i].name + ' (' + agents[i].role + ')</option>';
        }
        var reqOptions = '<option value="">无关联需求</option>';
        for (var i = 0; i < kanbanRequirements.length; i++) {
          reqOptions += '<option value="' + kanbanRequirements[i].id + '"' + (kanbanRequirements[i].id === task.requirement_id ? ' selected' : '') + '>' + kanbanRequirements[i].title + '</option>';
        }
        var statusOptions = '<option value="todo"' + (task.status==='todo'?' selected':'') + '>待执行</option><option value="in_progress"' + (task.status==='in_progress'?' selected':'') + '>进行中</option><option value="done"' + (task.status==='done'?' selected':'') + '>已完成</option>';
        showModal('编辑任务',
          '<form onsubmit="updateTask(event,' + taskId + ')"><div class="form-group"><label class="form-label">任务标题</label><input name="title" class="form-input" required value="' + escapeHtml(task.title || '') + '"></div><div class="form-group"><label class="form-label">任务描述</label><textarea name="description" class="form-textarea" placeholder="请描述任务内容">' + escapeHtml(task.description || '') + '</textarea></div><div class="form-group"><label class="form-label">关联需求</label><select name="requirement_id" class="form-select">' + reqOptions + '</select></div><div class="form-group"><label class="form-label">分配给</label><select name="assignee_id" class="form-select">' + agentOptions + '</select></div><div class="form-group"><label class="form-label">状态</label><select name="status" class="form-select">' + statusOptions + '</select></div><div class="form-group"><label class="form-label">优先级</label><select name="priority" class="form-select"><option value="p0"' + (task.priority==='p0'?' selected':'') + '>P0 - 紧急</option><option value="p1"' + (task.priority==='p1'?' selected':'') + '>P1 - 高</option><option value="p2"' + (task.priority==='p2'?' selected':'') + '>P2 - 中</option></select></div></form>',
          '<button type="button" class="btn btn-secondary" onclick="closeModal()">取消</button><button type="submit" class="btn btn-primary">保存</button>'
        );
      } catch (e) {
        showToast('error', '加载失败', e.message);
      }
    }

    function updateTask(e, taskId) {
      e.preventDefault();
      var form = e.target;
      api('/api/tasks/' + taskId, {
        method: 'PATCH',
