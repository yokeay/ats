          html += '</tr>';
        }
        tbody.innerHTML = html;
      }

      document.getElementById('reqPagerInfo').textContent = '共 ' + reqPager.total + ' 条';
      var pagerHtml = '';
      if (reqPager.totalPages > 1) {
        if (reqPager.page > 1) pagerHtml += '<button class="btn btn-sm" onclick="goToReqPage(' + (reqPager.page - 1) + ')">‹</button>';
        for (var pg = 1; pg <= reqPager.totalPages; pg++) {
          if (pg === 1 || pg === reqPager.totalPages || (pg >= reqPager.page - 1 && pg <= reqPager.page + 1)) {
            pagerHtml += '<button class="btn btn-sm' + (pg === reqPager.page ? ' btn-primary' : '') + '" onclick="goToReqPage(' + pg + ')">' + pg + '</button>';
          } else if (pg === reqPager.page - 2 || pg === reqPager.page + 2) {
            pagerHtml += '<span style="padding:4px">...</span>';
          }
        }
        if (reqPager.page < reqPager.totalPages) pagerHtml += '<button class="btn btn-sm" onclick="goToReqPage(' + (reqPager.page + 1) + ')">›</button>';
      }
      document.getElementById('reqPager').innerHTML = pagerHtml;
    }

