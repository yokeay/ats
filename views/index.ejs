        document.getElementById('drawerBody').innerHTML =
          '<div style="padding:20px">' +
          '<div style="margin-bottom:20px"><span class="priority-tag ' + req.priority + '">' + (req.priority || '').toUpperCase() + '</span> <span class="status-badge ' + st.class + '">' + st.text + '</span></div>' +
