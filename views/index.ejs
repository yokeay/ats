    // 获取需求成员（支持创建和编辑两种容器）
    function getSelectedMembers() {
      var members = [];
      var checkboxes = document.querySelectorAll('#req-members input[type="checkbox"]:checked, #edit-req-members input[type="checkbox"]:checked');
      for (var i = 0; i < checkboxes.length; i++) {
        var cb = checkboxes[i];
        members.push({
          agent_id: cb.dataset.agentId,
          role: cb.dataset.role
        });
      }
      return members;
    }

    function submitCreateRequirement() {
      var title = document.getElementById('cr-title').value;
      var desc = document.getElementById('cr-desc').value;
      var projectId = document.getElementById('cr-project').value;
      var ownerId = document.getElementById('cr-owner').value;
      var priority = document.getElementById('cr-priority').value;
      var planStart = document.getElementById('cr-plan-start').value;
      var planEnd = document.getElementById('cr-plan-end').value;
      var members = getSelectedMembers();

      if (!title) {
        showToast('error', '错误', '需求名称不能为空');
        return;
      }

      api('/api/requirements', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({
          title: title,
          description: desc,
          project_id: projectId || null,
          owner_id: ownerId || null,
          priority: priority,
          plan_start_time: planStart || null,
          plan_end_time: planEnd || null,
          members: members
        })
      }).then(function() {
        closeModal();
        showToast('success', '创建成功', '需求已创建');
        loadRequirements();
      }).catch(function(e) {
        showToast('error', '创建失败', e.message);
      });
    }

