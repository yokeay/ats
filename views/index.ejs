          html += '<td><span class="priority-tag ' + r.priority + '">' + (priorityMap[r.priority] || r.priority) + '</span></td>';
          html += '<td><span class="status-badge ' + st.class + '">' + st.text + '</span></td>';
          html += '<td>' + (r.owner_emoji || '') + ' ' + (r.owner_name || '<span style="color:var(--text-muted)">-</span>') + '</td>';
          html += '<td style="font-size:12px;color:var(--text-muted)">' + planTime + '</td>';
          html += '<td style="font-size:12px">' + r.created_at + '</td>';
