          timelineHtml += '<div class="timeline-item done"><div class="timeline-dot"></div><div class="timeline-content"><div class="timeline-title">评审通过</div><div class="timeline-time">' + req.review_time + '</div></div></div>';
        }
        if (req.status === 'in_progress' || req.status === 'done') {
          timelineHtml += '<div class="timeline-item done"><div class="timeline-dot"></div><div class="timeline-content"><div class="timeline-title">开始开发</div><div class="timeline-time">' + (req.updated_at || '') + '</div></div></div>';
        }
        if (req.status === 'done' && req.completed_at) {
          timelineHtml += '<div class="timeline-item done"><div class="timeline-dot"></div><div class="timeline-content"><div class="timeline-title">已完成</div><div class="timeline-time">' + req.completed_at + '</div></div></div>';
        }
        timelineHtml += '</div>';

        var planTime = '-';
        if (req.plan_start_time || req.plan_end_time) {
          var s = req.plan_start_time ? req.plan_start_time.split(' ')[0] : '-';
          var e = req.plan_end_time ? req.plan_end_time.split(' ')[0] : '-';
