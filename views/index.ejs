            var memberHtml = '';
            if (req.members && req.members.length > 0) {
              for (var mi = 0; mi < req.members.length; mi++) {
                var m = req.members[mi];
                memberHtml += '<div style="display:inline-flex;align-items:center;gap:4px;padding:6px 12px;background:var(--bg-secondary);border-radius:20px;font-size:13px"><span>' + (m.agent_emoji || '') + '</span><span>' + (m.agent_name || '') + '</span><span style="color:var(--text-muted);font-size:11px">(' + (m.agent_role || '') + ')</span></div>';
