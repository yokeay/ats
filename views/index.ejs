    // ===== 技术方案管理 =====
    var techPlansPage = 1;

    function loadTechPlans(page) {
      if (page !== undefined) techPlansPage = page;
      var search = document.getElementById('tpSearch').value;
      var reqId = document.getElementById('tpReqFilter').value;
      var cat = document.getElementById('tpCatFilter').value;
      var audit = document.getElementById('tpAuditFilter').value;
      var status = document.getElementById('tpStatusFilter').value;

      var params = '?page=' + techPlansPage + '&pageSize=20';
      if (search) params += '&search=' + encodeURIComponent(search);
      if (reqId) params += '&requirement_id=' + reqId;
      if (cat) params += '&category=' + cat;
      if (audit) params += '&audit_status=' + audit;
      if (status) params += '&status=' + status;

      api('/api/tech-plans' + params).then(function(data) {
        renderTechPlans(data.list);
        renderTechPlansPagination(data);
      }).catch(function(e) {
        showToast('error', '加载失败', e.message);
      });
    }

    function renderTechPlans(list) {
      var tb = document.getElementById('techPlansTableBody');
      if (!list || list.length === 0) {
        tb.innerHTML = '<tr><td colspan="11" style="text-align:center;padding:40px;color:var(--text-muted)">暂无技术方案</td></tr>';
        return;
      }
      var catMap = {ui: 'UI原型', frontend: '前端', backend: '后端', test: '测试', ops: '运维'};
      var phaseMap = {ui: {text: 'UI', class: 'pending'}, frontend: {text: '前端', class: 'pending'}, backend: {text: '后端', class: 'in_progress'}, test: {text: '测试', class: 'done'}, ops: {text: '运维', class: 'done'}};
      var auditMap = {pending: {text: '待审核', class: 'pending'}, pass: {text: '通过', class: 'done'}, reject: {text: '驳回', class: 'in_progress'}};
      var statusMap = {generating: {text: '生成中', class: 'pending'}, review: {text: '待评审', class: 'pending'}, in_progress: {text: '进行中', class: 'in_progress'}, done: {text: '已完成', class: 'done'}};
      var html = '';
      for (var i = 0; i < list.length; i++) {
