          '<td style="width:120px"><span style="cursor:pointer;color:var(--accent-blue)" onclick="closeDrawer();setTimeout(function(){showProjectDrawer(' + (tp.project_id || 0) + ')},100)">' + (tp.project_name || '<span style="color:var(--text-muted)">-</span>') + '</span></td>' +
          '<td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><span style="cursor:pointer;color:var(--accent-blue)" onclick="closeDrawer();setTimeout(function(){showRequirementDrawer(' + tp.requirement_id + ')},100)" title="' + escapeHtml(tp.requirement_title || '') + '">' + escapeHtml(tp.requirement_title || '') + '</span></td>' +
          '<td style="width:70px"><span class="code-tag" style="font-size:11px;cursor:pointer" onclick="showTechPlanDetail(' + tp.id + ')">' + (catMap[tp.category] || tp.category) + '</span></td>' +
          '<td style="width:70px"><span class="status-badge ' + pm.class + '" style="font-size:10px">' + pm.text + '</span></td>' +
          '<td style="width:100px">' + (tp.author_emoji || '') + ' ' + (tp.author_name || '') + '</td>' +
          '<td style="width:60px"><span style="cursor:pointer;color:var(--accent-blue);font-weight:600" onclick="showTechPlanVersions(' + tp.requirement_id + ', \'' + tp.category + '\')">V' + tp.version + '</span></td>' +
          '<td style="width:90px"><span class="status-badge ' + am.class + '">' + am.text + '</span></td>' +
          '<td style="width:90px"><span class="status-badge ' + sm.class + '">' + sm.text + '</span></td>' +
          '<td style="width:140px;font-size:12px;color:var(--text-muted)">' + (tp.updated_at || '') + '</td>' +
          '<td style="width:200px;white-space:nowrap">' +
            '<button class="btn-icon" onclick="showEditTechPlan(' + tp.id + ')" title="编辑">✏️</button>' +
            '<button class="btn-icon" onclick="showAuditTechPlan(' + tp.id + ')" title="审核" style="color:var(--accent-blue)">📝</button>' +
            '<button class="btn-icon' + (canReview ? '' : ' disabled') + '" onclick="' + (canReview ? 'reviewTechPlan(' + tp.id + ')' : '') + '" title="评审' + (canReview ? '' : '（需审核通过）') + '" style="color:' + (canReview ? 'var(--success)' : 'var(--text-muted)') + '">✅</button>' +
            '<button class="btn-icon" onclick="deleteTechPlan(' + tp.id + ')" title="删除" style="color:var(--danger)">🗑️</button>' +
          '</td></tr>';
      }
      tb.innerHTML = html;
    }

    function renderTechPlansPagination(data) {
      var pg = document.getElementById('techPlansPagination');
      if (!data || data.totalPages <= 1) { pg.innerHTML = ''; return; }
      var html = '<button class="btn btn-secondary" onclick="loadTechPlans(' + (techPlansPage - 1) + ')" ' + (techPlansPage <= 1 ? 'disabled' : '') + '>上一页</button>';
      html += '<span style="padding:0 12px">第 ' + data.page + ' / ' + data.totalPages + ' 页，共 ' + data.total + ' 条</span>';
      html += '<button class="btn btn-secondary" onclick="loadTechPlans(' + (techPlansPage + 1) + ')" ' + (techPlansPage >= data.totalPages ? 'disabled' : '') + '>下一页</button>';
      pg.innerHTML = html;
    }

    // 加载需求下拉
    function loadReqOptions() {
      api('/api/requirements').then(function(data) {
        var reqs = data.list || data || [];
        var sel = document.getElementById('tpReqFilter');
        var sel2 = document.getElementById('ctp-req');
        var html = '<option value="">全部需求</option>';
        var html2 = '<option value="">选择需求</option>';
        for (var i = 0; i < reqs.length; i++) {
          html += '<option value="' + reqs[i].id + '">' + escapeHtml(reqs[i].title) + '</option>';
          html2 += '<option value="' + reqs[i].id + '">' + escapeHtml(reqs[i].title) + '</option>';
        }
        if (sel) sel.innerHTML = html;
        if (sel2) sel2.innerHTML = html2;
      }).catch(function(e) { console.error(e); });
    }

    // 新建技术方案
    function showCreateTechPlan() {
      var catOptions = '<option value="ui">UI原型</option><option value="frontend">前端</option><option value="backend">后端</option><option value="test">测试</option><option value="ops">运维</option>';
      var authorOptions = '<option value="">选择作者</option>';
      for (var i = 0; i < agents.length; i++) {
        authorOptions += '<option value="' + agents[i].id + '">' + agents[i].emoji + ' ' + agents[i].name + '</option>';
      }
      showModal('新建技术方案',
        '<div id="createTpForm"><div class="form-group"><label class="form-label">需求 <span style="color:red">*</span></label><select id="ctp-req" class="form-select"><option value="">选择需求</option></select></div><div class="form-group"><label class="form-label">类别 <span style="color:red">*</span></label><select id="ctp-cat" class="form-select">' + catOptions + '</select></div><div class="form-group"><label class="form-label">作者 <span style="color:red">*</span></label><select id="ctp-author" class="form-select">' + authorOptions + '</select></div><div class="form-group"><label class="form-label">方案内容</label><textarea id="ctp-content" class="form-textarea" rows="8" placeholder="请详细描述技术方案..."></textarea></div></div>',
        '<button type="button" class="btn btn-secondary" onclick="closeModal()">取消</button><button type="button" class="btn btn-primary" onclick="submitCreateTechPlan()">创建</button>',
        '600px'
      );
      loadReqOptions();
    }

    function submitCreateTechPlan() {
      var reqId = document.getElementById('ctp-req').value;
      var cat = document.getElementById('ctp-cat').value;
      var authorId = document.getElementById('ctp-author').value;
      var content = document.getElementById('ctp-content').value;

      if (!reqId || !cat || !authorId) {
        showToast('error', '错误', '需求、类别、作者不能为空');
        return;
      }

      api('/api/tech-plans', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({requirement_id: parseInt(reqId), category: cat, author_id: authorId, content: content})
      }).then(function() {
        closeModal();
        showToast('success', '创建成功', '技术方案已创建');
        loadTechPlans();
      }).catch(function(e) {
        showToast('error', '创建失败', e.message);
      });
    }

    // 编辑技术方案
    function showEditTechPlan(id) {
      api('/api/tech-plans/' + id).then(function(tp) {
        var catOptions = '<option value="ui"' + (tp.category === 'ui' ? ' selected' : '') + '>UI原型</option><option value="frontend"' + (tp.category === 'frontend' ? ' selected' : '') + '>前端</option><option value="backend"' + (tp.category === 'backend' ? ' selected' : '') + '>后端</option><option value="test"' + (tp.category === 'test' ? ' selected' : '') + '>测试</option><option value="ops"' + (tp.category === 'ops' ? ' selected' : '') + '>运维</option>';
        showModal('编辑技术方案',
          '<div id="editTpForm"><div class="form-group"><label class="form-label">类别</label><select id="etp-cat" class="form-select">' + catOptions + '</select></div><div class="form-group"><label class="form-label">方案内容 <span style="color:var(--warning)">（修改内容将新增版本，审核状态重置）</span></label><textarea id="etp-content" class="form-textarea" rows="8">' + escapeHtml(tp.content || '') + '</textarea></div></div>',
          '<button type="button" class="btn btn-secondary" onclick="closeModal()">取消</button><button type="button" class="btn btn-primary" onclick="submitEditTechPlan(' + id + ')">保存</button>',
          '600px'
        );
      }).catch(function(e) {
        showToast('error', '加载失败', e.message);
      });
    }

    function submitEditTechPlan(id) {
      var cat = document.getElementById('etp-cat').value;
      var content = document.getElementById('etp-content').value;

      api('/api/tech-plans/' + id, {
        method: 'PATCH',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({category: cat, content: content})
      }).then(function() {
        closeModal();
        showToast('success', '更新成功', '技术方案已更新');
        loadTechPlans();
      }).catch(function(e) {
        showToast('error', '更新失败', e.message);
      });
    }

    // 删除技术方案
    function deleteTechPlan(id) {
      if (!confirm('确定要删除该技术方案吗？')) return;
      api('/api/tech-plans/' + id, { method: 'DELETE' })
        .then(function() {
          showToast('success', '删除成功', '技术方案已删除');
          loadTechPlans();
        }).catch(function(e) {
          showToast('error', '删除失败', e.message);
        });
    }

    // 审核技术方案
    function showAuditTechPlan(id) {
      document.getElementById('drawerTitle').textContent = '审核技术方案';
      document.getElementById('drawerBody').innerHTML =
        '<div style="padding:20px">' +
        '<div style="margin-bottom:16px"><div style="font-size:14px;font-weight:600;margin-bottom:12px">请选择审核结果</div>' +
        '<div style="display:flex;gap:8px;margin-bottom:12px">' +
        '<button class="btn btn-primary" onclick="document.getElementById(\'auditResult\').value=\'pass\';document.getElementById(\'auditCommentDiv\').style.display=\'none\';this.style.fontWeight=\'bold\';this.parentElement.querySelectorAll(\'button\')[1].style.fontWeight=\'normal\'">✅ 通过</button>' +
        '<button class="btn btn-danger" onclick="document.getElementById(\'auditResult\').value=\'reject\';document.getElementById(\'auditCommentDiv\').style.display=\'block\';this.style.fontWeight=\'bold\';this.parentElement.querySelectorAll(\'button\')[0].style.fontWeight=\'normal\'">❌ 驳回</button>' +
        '</div><input type="hidden" id="auditResult" value="pass"></div>' +
        '<div id="auditCommentDiv" style="display:none;margin-bottom:16px"><label class="form-label">驳回原因 <span style="color:red">*</span></label><textarea id="auditComment" class="form-textarea" rows="4" placeholder="请填写驳回原因，负责人将收到通知"></textarea></div>' +
        '<div style="text-align:right;margin-top:16px"><button class="btn btn-secondary" onclick="closeDrawer()">取消</button> <button class="btn btn-primary" onclick="submitAuditTechPlan(' + id + ')">确认审核</button></div>' +
        '</div>';
      document.getElementById('drawerOverlay').classList.add('show');
      document.getElementById('taskDrawer').classList.add('show');
    }

    function submitAuditTechPlan(id) {
      var result = document.getElementById('auditResult').value;
      var comment = document.getElementById('auditComment').value;
      if (result === 'reject' && !comment.trim()) {
        showToast('error', '错误', '驳回时必须填写审核意见');
        return;
      }
      api('/api/tech-plans/' + id + '/audit', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({result: result, comment: comment})
      }).then(function() {
        closeDrawer();
        showToast('success', '审核完成', result === 'pass' ? '审核通过，技术方案可进入评审阶段' : '已驳回，等待负责人修改后重新提交');
        loadTechPlans();
      }).catch(function(e) {
        showToast('error', '审核失败', e.message);
      });
    }

    // 评审技术方案
    function reviewTechPlan(id) {
      api('/api/tech-plans/' + id + '/review', { method: 'POST' })
        .then(function() {
          showToast('success', '评审通过', '技术方案已进入进行中阶段');
          loadTechPlans();
        }).catch(function(e) {
          showToast('error', '评审失败', e.message);
        });
    }

    // 技术方案版本历史抽屉
    async function showTechPlanVersions(requirementId, category) {
      try {
        var versions = await api('/api/tech-plans/versions/' + requirementId + '/' + category);
        var catMap = {ui: 'UI原型', frontend: '前端', backend: '后端', test: '测试', ops: '运维'};
        var auditMap = {pending: {text: '待审核', class: 'pending'}, pass: {text: '通过', class: 'done'}, reject: {text: '驳回', class: 'in_progress'}};
        var statusMap = {review: {text: '待评审', class: 'pending'}, in_progress: {text: '进行中', class: 'in_progress'}, done: {text: '已完成', class: 'done'}, generating: {text: '生成中', class: 'pending'}};
        var phaseMap = {ui: 'UI', frontend: '前端', backend: '后端', test: '测试', ops: '运维'};

        var html = '<div style="padding:20px;max-height:80vh;overflow-y:auto">' +
          '<div style="font-size:14px;font-weight:600;margin-bottom:16px">📋 版本历史 - ' + (catMap[category] || category) + '</div>' +
          '<div style="display:flex;flex-direction:column;gap:12px">';

        for (var i = 0; i < versions.length; i++) {
          var v = versions[i];
          var am = auditMap[v.audit_status] || {text: v.audit_status, class: ''};
          var sm = statusMap[v.review_status] || {text: v.review_status, class: ''};
          var isLatest = i === 0;
          var isGenerating = v.review_status === 'generating';
          var hasContent = v.content && v.content.trim();
          var mdHtml = hasContent ? marked.parse(v.content) : '';
          var leftColor = isLatest ? 'var(--accent-blue)' : 'var(--border-color)';

          // Deep Mode retrieval_log
          var retrievalHtml = '';
          try {
            var retrievalLog = typeof v.retrieval_log === 'string' ? JSON.parse(v.retrieval_log || '[]') : (v.retrieval_log || []);
            if (retrievalLog.length > 0) {
              retrievalHtml = '<div class="deep-mode-section" style="background:var(--bg-secondary);padding:12px;border-radius:8px;margin-bottom:16px">' +
                '<div style="font-weight:600;margin-bottom:10px;font-size:13px">🔍 Deep Mode 检索记录 <span style="font-size:11px;color:var(--text-muted);font-weight:normal">(' + retrievalLog.length + ' 个文件)</span></div>' +
                '<div style="display:flex;flex-direction:column;gap:8px">';
              for (var ri = 0; ri < retrievalLog.length; ri++) {
                var item = retrievalLog[ri];
                retrievalHtml += '<div style="background:var(--bg-primary);padding:10px;border-radius:6px;border-left:2px solid var(--accent-blue)">' +
                  '<div style="font-family:monospace;font-size:12px;color:var(--accent-blue);margin-bottom:4px">' + escapeHtml(item.file || '') + '</div>' +
                  '<div style="font-size:11px;color:var(--text-muted);margin-bottom:6px">检索原因：' + escapeHtml(item.reason || '') + '</div>' +
                  (item.snippet ? '<pre style="background:#1a1a2e;padding:8px;border-radius:4px;font-size:11px;overflow-x:auto;color:var(--text-primary);white-space:pre-wrap;word-break:break-all;max-height:80px;overflow-y:auto">' + escapeHtml((item.snippet || '').substring(0, 300)) + '</pre>' : '') +
                '</div>';
              }
              retrievalHtml += '</div></div>';
            }
          } catch (ex) {}

          html += '<div class="version-card" id="vc-' + i + '">' +
            '<div class="version-header"' + (isLatest ? ' style="border-left:3px solid var(--accent-blue)"' : '') + ' onclick="toggleVersion(this)">' +
              '<div style="display:flex;align-items:center;gap:10px">' +
                '<span style="font-size:12px;color:var(--text-muted)">' + (v.author_emoji || '') + '</span>' +
                '<span style="font-weight:600;font-size:14px">V' + v.version + '</span>' +
                (isLatest ? '<span class="code-tag" style="font-size:11px">最新</span>' : '') +
                '<span style="font-size:11px;color:var(--text-muted);padding:2px 6px;background:var(--bg-secondary);border-radius:4px">' + (phaseMap[v.dispatch_phase] || v.dispatch_phase || '') + '</span>' +
              '</div>' +
              '<div style="display:flex;align-items:center;gap:8px">' +
                '<span class="status-badge ' + am.class + '">' + am.text + '</span>' +
                '<span class="status-badge ' + sm.class + '">' + sm.text + '</span>' +
                '<span style="font-size:11px;color:var(--text-muted);margin-left:4px">' + (v.created_at || '') + '</span>' +
                '<span class="version-chevron">▶</span>' +
              '</div>' +
            '</div>' +
            '<div class="version-body"' + (isLatest ? '' : ' style="display:none"') + ' id="vb-' + i + '">' +
              (v.audit_comment ? '<div class="audit-comment">📝 审核意见：' + escapeHtml(v.audit_comment) + '</div>' : '') +
              retrievalHtml +
              (isGenerating ? '<div style="text-align:center;padding:30px 0">' +
                '<div class="loading-spinner" style="margin:0 auto 12px"></div>' +
                '<div style="color:var(--text-muted);font-size:13px">Agent 正在生成方案内容，请稍候...</div></div>' :
               hasContent ? '<div class="md-content" style="max-height:40vh;overflow-y:auto;padding:16px;background:var(--bg-primary);border-radius:6px;border:1px solid var(--border-color)">' + mdHtml + '</div>' :
               '<div style="text-align:center;padding:30px 0;color:var(--text-muted);font-size:13px">暂无内容</div>') +
            '</div>' +
          '</div>';
        }
        html += '</div></div>';

        document.getElementById('drawerTitle').textContent = '版本历史';
        document.getElementById('drawerBody').innerHTML = html;
        document.getElementById('drawerOverlay').classList.add('show');
        document.getElementById('taskDrawer').classList.add('show');

        // Auto-expand latest version
        var firstHeader = document.querySelector('.version-header');
        var firstBody = document.getElementById('vb-0');
        var firstChevron = firstHeader ? firstHeader.querySelector('.version-chevron') : null;
        if (firstBody) { firstBody.style.display = 'block'; }
        if (firstChevron) { firstChevron.textContent = '▼'; }
      } catch (e) {
        showToast('error', '加载失败', e.message);
      }
    }

    function toggleVersion(el) {
      var body = el.nextElementSibling;
      var chevron = el.querySelector('.version-chevron');
      var isOpen = body.style.display !== 'none';
      body.style.display = isOpen ? 'none' : 'block';
      chevron.textContent = isOpen ? '▶' : '▼';
    }

