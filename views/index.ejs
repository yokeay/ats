    function submitEditProject(id) {
      var name = document.getElementById('ep-name').value;
      var desc = document.getElementById('ep-desc').value;
      var phase = document.getElementById('ep-phase').value;
      var status = document.getElementById('ep-status').value;
      var work_dir = document.getElementById('ep-work-dir').value;
      var start_command = document.getElementById('ep-start-cmd').value;
      var itemsText = document.getElementById('ep-items').value.trim();
      if (!name) {
        showToast('error', '错误', '项目名称不能为空');
        return;
      }
      api('/api/projects/' + id, {
        method: 'PATCH',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({name: name, description: desc, phase: phase, status: status, work_dir: work_dir, start_command: start_command})
      }).then(function() {
        // 更新配置项
        return api('/api/local-projects/' + id);
      }).then(function(lp) {
        // 删除旧配置项，重新写入
        return api('/api/local-projects/' + id, {method: 'DELETE', headers: {'Content-Type': 'application/json'}, body: '{}'}).then(function() {
          if (!itemsText) return Promise.resolve();
          var lines = itemsText.split('\n');
          var promises = [];
          for (var i = 0; i < lines.length; i++) {
            var line = lines[i].trim();
            if (!line) continue;
            var colonIdx = line.indexOf(':');
            if (colonIdx > 0) {
              promises.push(api('/api/local-projects/' + id + '/items', {method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({item_key: line.substring(0, colonIdx).trim(), item_value: line.substring(colonIdx + 1).trim()})}));
            }
          }
          return Promise.all(promises);
        });
      }).then(function() {
        closeModal();
        showToast('success', '更新成功', '项目已更新');
        loadProjects();
      }).catch(function(e) {
        showToast('error', '更新失败', e.message);
      });
    }

    function deleteProject(id) {
      if (!confirm('确定要删除该项目吗？')) return;
      api('/api/projects/' + id, { method: 'DELETE' })
        .then(function() {
          showToast('success', '删除成功', '项目已删除');
          loadProjects();
        }).catch(function(e) {
          showToast('error', '删除失败', e.message);
        });
    }

